# --- DEPENDENCIES ---
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- BUILD & OUTPUT ---
.next/
/out/
/build
/dist
/coverage
*.tsbuildinfo
next-env.d.ts

# --- ENVIRONMENT VARIABLES (SANGAT PENTING) ---
# Kita mengabaikan semua file env yang berisi rahasia (API Key, Password DB)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Jika kamu ingin berbagi template env, buat file bernama .env.example dan JANGAN di-ignore
# !.env.example

# --- IDE & EDITORS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# --- SYSTEM FILES ---
.DS_Store
Thumbs.db
*.pem

# --- LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- VERCEL ---
.vercel